# Application Configuration
APP_NAME=reciprocity-platform
APP_VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8000
HOST=0.0.0.0

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["*"]

# Database Configuration
REDIS_URL=redis://localhost:6380/0
DYNAMO_PROFILE_TABLE_NAME=user_profiles
DYNAMO_MATCHES_TABLE_NAME=user_matches
DYNAMO_FEEDBACK_TABLE_NAME=user_feedback
DYNAMO_CHAT_TABLE_NAME=ai_chat_records
DYNAMO_NOTIFIED_PAIRS_TABLE_NAME=notified_match_pairs

# AWS Configuration (for LocalStack)
# LocalStack accepts any credentials - these are just placeholders
# You can also omit these and let AWS SDK use default credential chain
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
DYNAMODB_ENDPOINT_URL=http://localhost:4566

# ─── Anthropic Configuration (4 dedicated keys for rate limit isolation) ───
ANTHROPIC_CHAT_KEY=sk-ant-api03-your-chat-key
ANTHROPIC_EXTRACTION_KEY=sk-ant-api03-your-extraction-key
ANTHROPIC_PREDICTION_KEY=sk-ant-api03-your-prediction-key
ANTHROPIC_MATCHING_KEY=sk-ant-api03-your-matching-key
# Fallback: shared key used if dedicated keys not set
ANTHROPIC_API_KEY=sk-ant-api03-your-shared-key

# ─── OpenAI Configuration (GPT-5.4 fallback for chat + extraction) ───
OPENAI_FALLBACK_KEY=sk-proj-your-openai-fallback-key
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
LLM_TEMPERATURE=1

# ─── Google Gemini Configuration (fallback for prediction + matching) ───
GEMINI_FALLBACK_KEY=your-gemini-fallback-api-key
GEMINI_EMBEDDINGS_KEY=your-gemini-embeddings-api-key

# ─── Embedding Configuration ───
# Set USE_GEMINI_EMBEDDINGS=true for Gemini text-embedding-004 (recommended)
USE_GEMINI_EMBEDDINGS=true
USE_OPENAI_EMBEDDINGS=false
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_DIMENSION=768
SIMILARITY_THRESHOLD=0.7

# Matchmaking Configuration
MAX_MATCHES_PER_CYCLE=10
SCHEDULED_RECALCULATE_MATCHES=true
SIMILARITY_UPPER_THRESHOLD=0.95

# Feedback Configuration (Point 3)
# Options: "requirements", "offerings", "both"
FEEDBACK_TARGET_PORTION=requirements

# PostgreSQL Configuration (for embedding storage)
DATABASE_URL=postgresql://reciprocity_user:reciprocity_pass@localhost:5433/reciprocity_ai

# Backend Integration  
RECIPROCITY_BACKEND_URL=http://localhost:3000/api

# API Security Configuration
# X-API-KEY for incoming requests (protects YOUR API endpoints)
API_KEY=your-secret-api-key-here

# X-API-KEY for outgoing webhook requests (authenticates with external backend)
WEBHOOK_API_KEY=external-backend-api-key-here

# Webhook Configuration
WEBHOOK_URL=http://localhost:8000/webhook-endpoint